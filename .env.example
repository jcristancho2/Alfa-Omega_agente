# ALFA-OMEGA environment
#
# Para simulacion local segura:
# - TRADING_MODE debe quedar en simulated.
# - Deja KAPSO_API_KEY vacio si no quieres enviar mensajes reales.
# - Supabase puede quedar vacio mientras uses LOCAL_DB_PATH.

# General
APP_ENV=development
TRADING_MODE=simulated
LOCAL_DB_PATH=data/local-db.json

# Risk engine
MIN_SIGNAL_SCORE=7
RISK_PER_TRADE_PCT=0.01
MAX_DAILY_RISK_PCT=0.03
MAX_OPEN_TRADES=3

# API and local services
API_PORT=4000
API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
DASHBOARD_PORT=3000
BROKER_GATEWAY_PORT=4100
WORKER_POLL_INTERVAL_SECONDS=10

# Dashboard
NEXT_PUBLIC_DASHBOARD_REFRESH_SECONDS=5

# Supabase
# Requerido solo para Edge Functions / fase Supabase real.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public Supabase client values for dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# TradingView
# TRADINGVIEW_WEBHOOK_SECRET protege el webhook de entrada.
# NEXT_PUBLIC_TRADINGVIEW_ENABLED controla el widget visual del dashboard.
TRADINGVIEW_WEBHOOK_SECRET=
NEXT_PUBLIC_TRADINGVIEW_ENABLED=false
NEXT_PUBLIC_TRADINGVIEW_SYMBOL=BINANCE:BTCUSDT

# Kapso / WhatsApp
# Si KAPSO_API_KEY esta vacio, el worker usa modo mock.
KAPSO_API_KEY=
KAPSO_PHONE_NUMBER_ID=
KAPSO_WEBHOOK_SECRET=
